generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model cancel_requests {
  cancel_request_id Int       @id @default(autoincrement())
  order_id          Int?
  reason            String?   @db.Text
  status            String?   @db.VarChar(50)
  created_at        DateTime? @default(now()) @db.DateTime(0)
  orders            orders?   @relation(fields: [order_id], references: [order_id], onDelete: Restrict, onUpdate: Restrict, map: "cancel_requests_ibfk_1")

  @@index([order_id], map: "order_id")
}

model cart_items {
  cart_item_id     Int               @id @default(autoincrement())
  cart_id          Int?
  variant_id       Int?
  quantity         Int?
  render_id        Int?
  created_at       DateTime?         @default(now()) @db.DateTime(0)
  carts            carts?            @relation(fields: [cart_id], references: [cart_id], onDelete: Restrict, onUpdate: Restrict, map: "cart_items_ibfk_1")
  product_variants product_variants? @relation(fields: [variant_id], references: [variant_id], onDelete: Restrict, onUpdate: Restrict, map: "cart_items_ibfk_2")
  mockup_renders   mockup_renders?   @relation(fields: [render_id], references: [render_id], onDelete: SetNull, onUpdate: Restrict, map: "cart_items_ibfk_3")

  @@index([cart_id], map: "cart_id")
  @@index([variant_id], map: "variant_id")
  @@index([render_id], map: "render_id")
}

model carts {
  cart_id     Int          @id @default(autoincrement())
  customer_id Int?
  updated_at  DateTime?    @default(now()) @db.DateTime(0)
  cart_items  cart_items[]
  customers   customers?   @relation(fields: [customer_id], references: [customer_id], onDelete: Restrict, onUpdate: Restrict, map: "carts_ibfk_1")

  @@index([customer_id], map: "customer_id")
}

model categories {
  category_id Int        @id @default(autoincrement())
  name        String?    @db.VarChar(150)
  description String?    @db.Text
  thumbnail   String?    @db.Text
  status      String?    @db.VarChar(50)
  created_at  DateTime?  @default(now()) @db.DateTime(0)
  updated_at  DateTime?  @default(now()) @db.DateTime(0)
  products    products[]
}

model customer_addresses {
  address_id     Int        @id @default(autoincrement())
  customer_id    Int?
  receiver_name  String?    @db.VarChar(150)
  phone          String?    @db.VarChar(20)
  ward_id        Int?
  address_detail String?    @db.Text
  is_default     Boolean?
  created_at     DateTime?  @default(now()) @db.DateTime(0)
  customers      customers? @relation(fields: [customer_id], references: [customer_id], onDelete: Restrict, onUpdate: Restrict, map: "customer_addresses_ibfk_1")
  orders         orders[]

  @@index([customer_id], map: "customer_id")
}

model customers {
  customer_id        Int                  @id
  loyalty_point      Int?                 @default(0)
  level              Int?                 @default(1)
  status             customers_status?
  created_at         DateTime?            @default(now()) @db.DateTime(0)
  carts              carts[]
  customer_addresses customer_addresses[]
  users              users                @relation(fields: [customer_id], references: [user_id], onUpdate: Restrict, map: "customers_ibfk_1")
  mockup_renders     mockup_renders[]
  orders             orders[]
  promotion_usages   promotion_usages[]
  reviews            reviews[]
}

model order_items {
  order_item_id    Int               @id @default(autoincrement())
  order_id         Int?
  variant_id       Int?
  quantity         Int?
  unit_price       Decimal?          @db.Decimal(10, 2)
  render_id        Int?
  orders           orders?           @relation(fields: [order_id], references: [order_id], onDelete: Restrict, onUpdate: Restrict, map: "order_items_ibfk_1")
  product_variants product_variants? @relation(fields: [variant_id], references: [variant_id], onDelete: Restrict, onUpdate: Restrict, map: "order_items_ibfk_2")
  mockup_renders   mockup_renders?   @relation(fields: [render_id], references: [render_id], onDelete: SetNull, onUpdate: Restrict, map: "order_items_ibfk_3")
  reviews          reviews[]

  @@index([order_id], map: "order_id")
  @@index([variant_id], map: "variant_id")
  @@index([render_id], map: "render_id")
}

model orders {
  order_id            Int                   @id @default(autoincrement())
  customer_id         Int?
  address_id          Int?
  order_status        String?               @db.VarChar(50)
  payment_status      String?               @db.VarChar(50)
  total_amount        Decimal?              @db.Decimal(14, 2)
  created_at          DateTime?             @default(now()) @db.DateTime(0)
  cancel_requests     cancel_requests[]
  order_items         order_items[]
  customers           customers?            @relation(fields: [customer_id], references: [customer_id], onDelete: Restrict, onUpdate: Restrict, map: "orders_ibfk_1")
  wards               customer_addresses?   @relation(fields: [address_id], references: [address_id], onDelete: Restrict, onUpdate: Restrict, map: "orders_ibfk_3")
  payments            payments[]
  promotion_usages    promotion_usages[]
  refunds             refunds[]
  shipments           shipments[]
  wallet_transactions wallet_transactions[]

  @@index([address_id], map: "address_id")
  @@index([customer_id], map: "customer_id")
}

model payments {
  payment_id       Int       @id @default(autoincrement())
  order_id         Int?
  payment_method   String?   @db.VarChar(100)
  provider         String?   @db.VarChar(100)
  amount           Decimal?  @db.Decimal(14, 2)
  status           String?   @db.VarChar(50)
  transaction_code String?   @db.VarChar(150)
  created_at       DateTime? @default(now()) @db.DateTime(0)
  orders           orders?   @relation(fields: [order_id], references: [order_id], onDelete: Restrict, onUpdate: Restrict, map: "payments_ibfk_1")

  @@index([order_id], map: "order_id")
}

model product_media {
  media_id   Int                       @id @default(autoincrement())
  product_id Int?
  media_url  String?                   @db.Text
  media_type product_media_media_type? @default(image)
  is_primary Boolean?
  products   products?                 @relation(fields: [product_id], references: [product_id], onDelete: Restrict, onUpdate: Restrict, map: "product_media_ibfk_1")

  @@index([product_id], map: "product_id")
}

model product_variants {
  variant_id       Int                @id @default(autoincrement())
  product_id       Int?
  sku              String?            @unique(map: "sku") @db.VarChar(100)
  color            String?            @db.VarChar(50)
  size             String?            @db.VarChar(50)
  price            Decimal?           @db.Decimal(12, 2)
  stock_quantity   Int?
  image_url        String?            @db.Text
  cart_items       cart_items[]
  order_items      order_items[]
  mockup_templates mockup_templates[]
  products         products?          @relation(fields: [product_id], references: [product_id], onDelete: Restrict, onUpdate: Restrict, map: "product_variants_ibfk_1")

  @@index([product_id], map: "product_id")
}

model products {
  product_id       Int                @id @default(autoincrement())
  seller_id        Int?
  category_id      Int?
  product_name     String?            @db.VarChar(200)
  description      String?            @db.Text
  status           products_status?
  created_at       DateTime?          @default(now()) @db.DateTime(0)
  updated_at       DateTime?          @default(now()) @db.DateTime(0)
  mockup_renders   mockup_renders[]
  product_media    product_media[]
  product_variants product_variants[]
  sellers          sellers?           @relation(fields: [seller_id], references: [user_id], onDelete: Restrict, onUpdate: Restrict, map: "products_ibfk_1")
  categories       categories?        @relation(fields: [category_id], references: [category_id], onDelete: Restrict, onUpdate: Restrict, map: "products_ibfk_2")
  reviews          reviews[]

  @@index([category_id], map: "category_id")
  @@index([seller_id], map: "seller_id")
}

model promotion_usages {
  promotion_usage_id Int         @id @default(autoincrement())
  promotion_id       Int?
  customer_id        Int?
  order_id           Int?
  used_at            DateTime?   @default(now()) @db.DateTime(0)
  promotions         promotions? @relation(fields: [promotion_id], references: [promotion_id], onDelete: Restrict, onUpdate: Restrict, map: "promotion_usages_ibfk_1")
  customers          customers?  @relation(fields: [customer_id], references: [customer_id], onDelete: Restrict, onUpdate: Restrict, map: "promotion_usages_ibfk_2")
  orders             orders?     @relation(fields: [order_id], references: [order_id], onDelete: Restrict, onUpdate: Restrict, map: "promotion_usages_ibfk_3")

  @@index([customer_id], map: "customer_id")
  @@index([order_id], map: "order_id")
  @@index([promotion_id], map: "promotion_id")
}

model promotions {
  promotion_id     Int                        @id @default(autoincrement())
  promotion_type   promotions_promotion_type?
  discount_value   Decimal?                   @db.Decimal(12, 2)
  min_order_value  Decimal?                   @db.Decimal(12, 2)
  start_date       DateTime?                  @db.Date
  end_date         DateTime?                  @db.Date
  status           String?                    @db.VarChar(50)
  promotion_usages promotion_usages[]
}

model provinces {
  province_id            Int                   @id @default(autoincrement())
  name                   String                @db.VarChar(255)
  name_en                String?               @db.VarChar(255)
  full_name              String                @db.VarChar(255)
  full_name_en           String?               @db.VarChar(255)
  code_name              String?               @db.VarChar(255)
  administrative_unit_id Int?
  administrative_units   administrative_units? @relation(fields: [administrative_unit_id], references: [id], onDelete: Restrict, onUpdate: Restrict)
  wards                  wards[]

  @@index([administrative_unit_id], map: "idx_provinces_unit")
}

model refunds {
  id         Int             @id @default(autoincrement())
  order_id   Int
  reason     String?         @db.Text
  status     refunds_status? @default(pending)
  created_at DateTime?       @default(now()) @db.DateTime(0)
  orders     orders          @relation(fields: [order_id], references: [order_id], onUpdate: Restrict, map: "refunds_ibfk_1")

  @@index([order_id], map: "order_id")
}

model review_media {
  id         Int                      @id @default(autoincrement())
  review_id  Int
  media_url  String?                  @db.VarChar(255)
  media_type review_media_media_type? @default(image)
  reviews    reviews                  @relation(fields: [review_id], references: [review_id], onUpdate: Restrict, map: "review_media_ibfk_1")

  @@index([review_id], map: "review_id")
}

model reviews {
  review_id     Int            @id @default(autoincrement())
  customer_id   Int?
  product_id    Int?
  order_item_id Int?
  rating        Int?
  content       String?        @db.Text
  media_url     String?        @db.Text
  created_at    DateTime?      @default(now()) @db.DateTime(0)
  review_media  review_media[]
  customers     customers?     @relation(fields: [customer_id], references: [customer_id], onDelete: Restrict, onUpdate: Restrict, map: "reviews_ibfk_1")
  products      products?      @relation(fields: [product_id], references: [product_id], onDelete: Restrict, onUpdate: Restrict, map: "reviews_ibfk_2")
  order_items   order_items?   @relation(fields: [order_item_id], references: [order_item_id], onDelete: Restrict, onUpdate: Restrict, map: "reviews_ibfk_3")

  @@index([customer_id], map: "customer_id")
  @@index([order_item_id], map: "order_item_id")
  @@index([product_id], map: "product_id")
}

model sellers {
  user_id           Int        @id
  shop_name         String?    @db.VarChar(150)
  rating            Decimal?   @db.Decimal(2, 1)
  theme_description String?    @db.Text
  created_at        DateTime?  @default(now()) @db.DateTime(0)
  updated_at        DateTime?  @default(now()) @db.DateTime(0)
  products          products[]
  users             users      @relation(fields: [user_id], references: [user_id], onUpdate: Restrict, map: "sellers_ibfk_1")
  wallets           wallets[]
}

model shipments {
  shipment_id            Int       @id @default(autoincrement())
  order_id               Int?
  tracking_number        String?   @db.VarChar(150)
  carrier                String?   @db.VarChar(100)
  shipping_fee           Decimal?  @db.Decimal(12, 2)
  status                 String?   @db.VarChar(50)
  expected_delivery_date DateTime? @db.Date
  orders                 orders?   @relation(fields: [order_id], references: [order_id], onDelete: Restrict, onUpdate: Restrict, map: "shipments_ibfk_1")

  @@index([order_id], map: "order_id")
}

model users {
  user_id        Int           @id @default(autoincrement())
  tiktok_user_id String?       @unique(map: "tiktok_user_id") @db.VarChar(100)
  username       String?       @db.VarChar(100)
  password_hash  String?       @db.VarChar(255)
  email          String?       @db.VarChar(100)
  phone          String?       @db.VarChar(20)
  full_name      String?       @db.VarChar(150)
  avatar_url     String?       @db.Text
  role           users_role?
  status         users_status?
  created_at     DateTime?     @default(now()) @db.DateTime(0)
  updated_at     DateTime?     @default(now()) @db.DateTime(0)
  customers      customers?
  sellers        sellers?
}

model wallet_transactions {
  transaction_id   Int                                   @id @default(autoincrement())
  wallet_id        Int?
  order_id         Int?
  transaction_type wallet_transactions_transaction_type?
  amount           Decimal?                              @db.Decimal(14, 2)
  created_at       DateTime?                             @default(now()) @db.DateTime(0)
  wallets          wallets?                              @relation(fields: [wallet_id], references: [wallet_id], onDelete: Restrict, onUpdate: Restrict, map: "wallet_transactions_ibfk_1")
  orders           orders?                               @relation(fields: [order_id], references: [order_id], onDelete: Restrict, onUpdate: Restrict, map: "wallet_transactions_ibfk_2")

  @@index([order_id], map: "order_id")
  @@index([wallet_id], map: "wallet_id")
}

model wallets {
  wallet_id           Int                   @id @default(autoincrement())
  seller_id           Int?
  available_balance   Decimal?              @db.Decimal(14, 2)
  pending_balance     Decimal?              @db.Decimal(14, 2)
  withdrawn_balance   Decimal?              @db.Decimal(14, 2)
  total_revenue       Decimal?              @db.Decimal(14, 2)
  updated_at          DateTime?             @default(now()) @db.DateTime(0)
  wallet_transactions wallet_transactions[]
  sellers             sellers?              @relation(fields: [seller_id], references: [user_id], onDelete: Restrict, onUpdate: Restrict, map: "wallets_ibfk_1")

  @@index([seller_id], map: "seller_id")
}

model wards {
  ward_id                Int                   @id @default(autoincrement())
  name                   String                @db.VarChar(255)
  name_en                String?               @db.VarChar(255)
  full_name              String?               @db.VarChar(255)
  full_name_en           String?               @db.VarChar(255)
  code_name              String?               @db.VarChar(255)
  province_id            Int?
  administrative_unit_id Int?
  administrative_units   administrative_units? @relation(fields: [administrative_unit_id], references: [id], onDelete: Restrict, onUpdate: Restrict)
  provinces              provinces?            @relation(fields: [province_id], references: [province_id], onDelete: Restrict, onUpdate: Restrict, map: "wards_province_code_fkey")

  @@index([province_id], map: "idx_wards_province")
  @@index([administrative_unit_id], map: "idx_wards_unit")
}

model mockup_templates {
  template_id      Int               @id @default(autoincrement())
  variant_id       Int?
  name             String            @db.VarChar(255)
  description      String?           @db.Text
  mockup_uuid      String            @unique @db.VarChar(100)
  thumbnail_url    String?           @db.Text
  category         String?           @db.VarChar(100)
  smart_objects    String?           @db.LongText
  is_active        Boolean?          @default(true)
  created_at       DateTime?         @default(now()) @db.DateTime(0)
  product_variants product_variants? @relation(fields: [variant_id], references: [variant_id], onDelete: SetNull, onUpdate: Restrict, map: "mockup_templates_ibfk_1")
  mockup_renders   mockup_renders[]

  @@index([variant_id], map: "variant_id")
}

model mockup_renders {
  render_id          Int               @id @default(autoincrement())
  customer_id        Int?
  product_id         Int?
  template_id        Int?
  design_image_url   String?           @db.Text
  rendered_image_url String?           @db.Text
  render_config      String?           @db.LongText
  status             mockup_status?    @default(pending)
  error_message      String?           @db.Text
  created_at         DateTime?         @default(now()) @db.DateTime(0)
  updated_at         DateTime?         @default(now()) @db.DateTime(0)
  customers          customers?        @relation(fields: [customer_id], references: [customer_id], onDelete: Restrict, onUpdate: Restrict, map: "mockup_renders_ibfk_1")
  products           products?         @relation(fields: [product_id], references: [product_id], onDelete: Restrict, onUpdate: Restrict, map: "mockup_renders_ibfk_2")
  mockup_templates   mockup_templates? @relation(fields: [template_id], references: [template_id], onDelete: Restrict, onUpdate: Restrict, map: "mockup_renders_ibfk_3")
  order_items        order_items[]
  cart_items        cart_items[]

  @@index([customer_id], map: "customer_id")
  @@index([product_id], map: "product_id")
  @@index([template_id], map: "template_id")
}

model administrative_regions {
  id           Int     @id
  name         String  @db.VarChar(255)
  name_en      String  @db.VarChar(255)
  code_name    String? @db.VarChar(255)
  code_name_en String? @db.VarChar(255)
}

model administrative_units {
  id            Int         @id
  full_name     String?     @db.VarChar(255)
  full_name_en  String?     @db.VarChar(255)
  short_name    String?     @db.VarChar(255)
  short_name_en String?     @db.VarChar(255)
  code_name     String?     @db.VarChar(255)
  code_name_en  String?     @db.VarChar(255)
  provinces     provinces[]
  wards         wards[]
}

enum promotions_promotion_type {
  PERCENT
  FIXED
  FREESHIP
}

enum customers_status {
  active
  inactive
}

enum product_media_media_type {
  image
  video
}

enum refunds_status {
  pending
  approved
  rejected
}

enum review_media_media_type {
  image
  video
}

enum wallet_transactions_transaction_type {
  CREDIT
  DEBIT
  REFUND
}

enum products_status {
  active
  inactive
}

enum users_role {
  ADMIN
  SELLER
  CUSTOMER
}

enum users_status {
  active
  inactive
}

enum mockup_status {
  pending
  processing
  completed
  failed
}
